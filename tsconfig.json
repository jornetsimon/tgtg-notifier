{
  "compilerOptions": {
    "outDir": "./dist",
    "target": "ES2022",
    "strict": true,
    "module": "ES2022",
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "moduleResolution": "Node",
    "noImplicitAny": true,
    "alwaysStrict": true
  },
  "include": ["./src/**/*"],
  "ts-node": {
    "experimentalSpecifierResolution": "node",
    "transpileOnly": true,
    "esm": true,
  }
}
